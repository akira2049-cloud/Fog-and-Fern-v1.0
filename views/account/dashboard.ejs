<section class="page-hero compact"><div class="container"><small>MY ACCOUNT</small><h1>Hello, <%= user.full_name.split(' ')[0] %></h1></div></section><section class="section"><div class="container account-grid"><aside class="account-nav"><a class="active" href="/account">Dashboard</a><a href="/account/orders">Orders</a><form action="/auth/logout" method="post"><button>Logout</button></form></aside><div><div class="stats-grid"><div><small>ORDERS</small><b><%= stats.orders %></b></div><div><small>TOTAL SPENT</small><b>$<%= stats.spent.toFixed(2) %></b></div></div><div class="form-card"><h2>Profile</h2><form action="/account" method="post" class="form-grid"><label>Full name<input name="full_name" value="<%= user.full_name %>" required></label><label>Email<input value="<%= user.email %>" disabled></label><label>Phone<input name="phone" value="<%= user.phone||'' %>"></label><div><button class="btn-dark">Save profile</button></div></form></div><h2 class="mt-5">Recent orders</h2><%- include('orders-table',{orders}) %></div></div></section>