<section class="section"><div class="container narrow"><a href="/account/orders">← Back to orders</a><h1 class="mt-3"><%= order.order_number %></h1><p>Status: <span class="status"><%= order.status %></span></p><div class="receipt"><% items.forEach(i=>{ %><div><span><%= i.product_name %> × <%= i.quantity %></span><b>$<%= i.line_total.toFixed(2) %></b></div><% }) %><hr><div><span>Total</span><b>$<%= order.total.toFixed(2) %></b></div></div></div></section>