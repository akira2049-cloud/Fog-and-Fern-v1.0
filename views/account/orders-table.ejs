<div class="table-responsive"><table class="data-table"><thead><tr><th>Order</th><th>Date</th><th>Status</th><th>Total</th><th></th></tr></thead><tbody><% orders.forEach(o=>{ %><tr><td><%= o.order_number %></td><td><%= new Date(o.created_at).toLocaleDateString() %></td><td><span class="status"><%= o.status %></span></td><td>$<%= o.total.toFixed(2) %></td><td><a href="/account/orders/<%= o.id %>">View</a></td></tr><% }) %></tbody></table><% if(!orders.length){ %><p>No orders yet.</p><% } %></div>