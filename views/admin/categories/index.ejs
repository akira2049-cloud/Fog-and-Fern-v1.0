<div class="admin-card mb-4"><h2>Add category</h2><form action="/admin/categories" method="post" class="form-grid"><label>Name<input name="name" required></label><label>Image URL<input name="image_url"></label><label class="wide">Description<input name="description"></label><button class="btn-green">Add category</button></form></div><div class="admin-card"><table class="data-table"><thead><tr><th>Name</th><th>Products</th><th>Status</th><th>Update</th></tr></thead><tbody><% categories.forEach(c=>{ %><tr><form action="/admin/categories/<%= c.id %>" method="post"><td><input name="name" value="<%= c.name %>"></td><td><%= c.product_count %></td><td><label class="check"><input type="checkbox" name="active" <%= c.active?'checked':'' %>> Active</label></td><td><input type="hidden" name="description" value="<%= c.description||'' %>"><input type="hidden" name="image_url" value="<%= c.image_url||'' %>"><button class="small-btn">Save</button></form> <form class="inline" action="/admin/categories/<%= c.id %>/delete" method="post" onsubmit="return confirm('Delete category? Products will become uncategorized.')"><button class="danger-link">Delete</button></form></td></tr><% }) %></tbody></table></div>