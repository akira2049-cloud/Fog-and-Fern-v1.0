<div class="admin-stats"><div><i class="fa-solid fa-seedling"></i><span>Products</span><b><%= stats.products %></b></div><div><i class="fa-solid fa-box"></i><span>Orders</span><b><%= stats.orders %></b></div><div><i class="fa-solid fa-users"></i><span>Customers</span><b><%= stats.customers %></b></div><div><i class="fa-solid fa-dollar-sign"></i><span>Revenue</span><b>$<%= stats.revenue.toFixed(2) %></b></div><div><i class="fa-solid fa-envelope"></i><span>New messages</span><b><%= stats.messages %></b></div><div><i class="fa-solid fa-triangle-exclamation"></i><span>Low stock</span><b><%= stats.lowStock %></b></div></div><div class="admin-card"><div class="admin-card-head"><h2>Recent orders</h2><a href="/admin/orders">View all</a></div><div class="table-responsive"><table class="data-table"><thead><tr><th>Order</th><th>Customer</th><th>Status</th><th>Total</th><th></th></tr></thead><tbody><% recent.forEach(o=>{ %><tr><td><%= o.order_number %></td><td><%= o.customer_name %></td><td><span class="status"><%= o.status %></span></td><td>$<%= o.total.toFixed(2) %></td><td><a href="/admin/orders/<%= o.id %>">Open</a></td></tr><% }) %></tbody></table></div></div>