<div class="admin-card"><% messages.forEach(m=>{ %><article class="message-card <%= m.status==='New'?'unread':'' %>"><div><b><%= m.subject %></b><span><%= m.name %> · <%= m.email %> · <%= new Date(m.created_at).toLocaleString() %></span><p><%= m.message %></p></div><% if(m.status==='New'){ %><form action="/admin/messages/<%= m.id %>/read" method="post"><button class="small-btn">Mark read</button></form><% } %></article><% }) %><% if(!messages.length){ %><p>No messages.</p><% } %></div>