<div class="admin-grid-two"><div class="admin-card"><h2>Items</h2><div class="receipt"><% items.forEach(i=>{ %><div><span><%= i.product_name %> × <%= i.quantity %></span><b>$<%= i.line_total.toFixed(2) %></b></div><% }) %><hr><div><span>Total</span><b>$<%= order.total.toFixed(2) %></b></div></div></div><div class="admin-card"><h2>Customer and status</h2><p><b><%= order.customer_name %></b><br><%= order.email %><br><%= order.phone %></p><p><%= order.fulfillment==='delivery'?(order.address+', '+order.city+' '+order.zip_code):'Store pickup' %></p><form action="/admin/orders/<%= order.id %>/status" method="post"><label>Status<select name="status"><% ['Pending','Confirmed','Preparing','Ready for Pickup','Out for Delivery','Completed','Cancelled'].forEach(s=>{ %><option <%= order.status===s?'selected':'' %>><%= s %></option><% }) %></select></label><button class="btn-green mt-3">Update status</button></form></div></div>