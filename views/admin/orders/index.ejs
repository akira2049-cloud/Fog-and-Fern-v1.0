<div class="admin-card"><div class="table-responsive"><table class="data-table"><thead><tr><th>Order</th><th>Customer</th><th>Fulfillment</th><th>Status</th><th>Total</th><th>Date</th><th></th></tr></thead><tbody><% orders.forEach(o=>{ %><tr><td><%= o.order_number %></td><td><%= o.customer_name %></td><td><%= o.fulfillment %></td><td><span class="status"><%= o.status %></span></td><td>$<%= o.total.toFixed(2) %></td><td><%= new Date(o.created_at).toLocaleDateString() %></td><td><a href="/admin/orders/<%= o.id %>">Manage</a></td></tr><% }) %></tbody></table></div></div>