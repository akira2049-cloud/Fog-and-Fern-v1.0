<div class="admin-card"><form action="<%= product?'/admin/products/'+product.id:'/admin/products' %>" method="post" enctype="multipart/form-data" class="form-grid"><label>Product name<input name="name" value="<%= product?.name||'' %>" required></label><label>Category<select name="category_id"><option value="">No category</option><% categories.forEach(c=>{ %><option value="<%= c.id %>" <%= product?.category_id===c.id?'selected':'' %>><%= c.name %></option><% }) %></select></label><label>Price<input type="number" step="0.01" name="price" value="<%= product?.price??'' %>" required></label><label>Sale price<input type="number" step="0.01" name="sale_price" value="<%= product?.sale_price??'' %>"></label><label>Stock<input type="number" name="stock" min="0" value="<%= product?.stock??0 %>"></label><label>Difficulty<input name="difficulty" value="<%= product?.difficulty||'' %>"></label><label>Light requirement<input name="light_requirement" value="<%= product?.light_requirement||'' %>"></label><label>Water requirement<input name="water_requirement" value="<%= product?.water_requirement||'' %>"></label><label class="wide">Image URL<input name="image_url" value="<%= product?.image_url||'' %>"></label><label class="wide">Or upload image<input type="file" name="image" accept="image/png,image/jpeg,image/webp"></label><label class="wide">Description<textarea name="description" rows="6" required><%= product?.description||'' %></textarea></label><label class="check"><input type="checkbox" name="pet_safe" <%= product?.pet_safe?'checked':'' %>> Pet friendly</label><label class="check"><input type="checkbox" name="featured" <%= product?.featured?'checked':'' %>> Featured</label><label class="check"><input type="checkbox" name="active" <%= product?product.active?'checked':'':'checked' %>> Active</label><div class="wide"><button class="btn-green">Save product</button> <a href="/admin/products" class="btn-secondary-custom">Cancel</a></div></form></div>