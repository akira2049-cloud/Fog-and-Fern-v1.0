<div class="admin-actions"><a href="/admin/products/new" class="btn-green"><i class="fa-solid fa-plus"></i> Add product</a></div><div class="admin-card"><div class="table-responsive"><table class="data-table"><thead><tr><th>Plant</th><th>Category</th><th>Price</th><th>Stock</th><th>Status</th><th>Actions</th></tr></thead><tbody><% products.forEach(p=>{ %><tr><td><div class="table-product"><img src="<%= p.image_url %>"><b><%= p.name %></b></div></td><td><%= p.category_name||'—' %></td><td>$<%= (p.sale_price||p.price).toFixed(2) %></td><td><%= p.stock %></td><td><span class="status"><%= p.active?'Active':'Hidden' %></span></td><td><a href="/admin/products/<%= p.id %>/edit">Edit</a> <form class="inline" action="/admin/products/<%= p.id %>/delete" method="post" onsubmit="return confirm('Delete this product?')"><button class="danger-link">Delete</button></form></td></tr><% }) %></tbody></table></div></div>