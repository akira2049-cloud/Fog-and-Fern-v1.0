<section class="page-hero compact"><div class="container"><h1>Your cart</h1></div></section><section class="section"><div class="container"><% if(!items.length){ %><div class="empty"><i class="fa-solid fa-bag-shopping"></i><h2>Your cart is empty</h2><a href="/shop" class="btn-green">Continue shopping</a></div><% }else{ %><div class="cart-layout"><div><% items.forEach(i=>{ %><div class="cart-row"><img src="<%= i.image_url %>"><div><h3><a href="/shop/<%= i.slug %>"><%= i.name %></a></h3><span>$<%= i.unit_price.toFixed(2) %> each</span></div><form action="/cart/update/<%= i.id %>" method="post"><input type="number" name="quantity" min="0" max="<%= i.stock %>" value="<%= i.quantity %>"><button>Update</button></form><strong>$<%= i.line_total.toFixed(2) %></strong><form action="/cart/remove/<%= i.id %>" method="post"><button class="remove">×</button></form></div><% }) %></div><aside class="summary"><h2>Order summary</h2><div><span>Subtotal</span><strong>$<%= subtotal.toFixed(2) %></strong></div><p>Delivery is calculated at checkout. Free over $75.</p><a href="/checkout" class="btn-green block">Checkout</a><a href="/shop" class="text-center d-block mt-3">Continue shopping</a></aside></div><form action="/cart/clear" method="post"><button class="link-button">Clear cart</button></form><% } %></div></section>