<section class="page-hero compact"><div class="container"><h1>Checkout</h1></div></section><section class="section"><div class="container"><form action="/checkout" method="post" class="checkout-layout"><div class="form-card"><h2>Contact and fulfillment</h2><div class="form-grid"><label>Full name<input name="customer_name" required value="<%= user.full_name||'' %>"></label><label>Email<input type="email" name="email" required value="<%= user.email||'' %>"></label><label>Phone<input name="phone" required></label><label>Fulfillment<select name="fulfillment" id="fulfillment"><option value="delivery">Local delivery</option><option value="pickup">Store pickup</option></select></label><label class="wide delivery-field">Street address<input name="address"></label><label class="delivery-field">City<input name="city" value="San Francisco"></label><label class="delivery-field">ZIP code<input name="zip_code"></label><label>Payment<select name="payment_method"><option>Pay on delivery</option><option>Pay at pickup</option></select></label><label class="wide">Order notes<textarea name="notes"></textarea></label></div></div><aside class="summary"><h2>Your order</h2><% items.forEach(i=>{ %><div><span><%= i.name %> × <%= i.quantity %></span><strong>$<%= i.line_total.toFixed(2) %></strong></div><% }) %><hr><div><span>Subtotal</span><strong>$<%= subtotal.toFixed(2) %></strong></div><p>$9 delivery under $75. Pickup is free.</p><button class="btn-green block">Place order</button></aside></form></div></section>