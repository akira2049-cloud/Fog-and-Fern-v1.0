<section class="section"><div class="container"><div class="success-box"><i class="fa-solid fa-circle-check"></i><small>ORDER CONFIRMED</small><h1>Thank you, <%= order.customer_name %>!</h1><p>Your order number is <b><%= order.order_number %></b>. We will contact you using <%= order.email %>.</p><div class="receipt"><% items.forEach(i=>{ %><div><span><%= i.product_name %> × <%= i.quantity %></span><b>$<%= i.line_total.toFixed(2) %></b></div><% }) %><hr><div><span>Total</span><b>$<%= order.total.toFixed(2) %></b></div></div><a href="/shop" class="btn-green">Continue shopping</a></div></div></section>