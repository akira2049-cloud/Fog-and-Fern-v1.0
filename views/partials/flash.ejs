<% if(successMessages?.length||errorMessages?.length){ %><div class="container flash-wrap"><% successMessages.forEach(m=>{ %><div class="alert alert-success alert-dismissible fade show"><%= m %><button class="btn-close" data-bs-dismiss="alert"></button></div><% }) %><% errorMessages.forEach(m=>{ %><div class="alert alert-danger alert-dismissible fade show"><%= m %><button class="btn-close" data-bs-dismiss="alert"></button></div><% }) %></div><% } %>