<article class="product-card"><a href="/shop/<%= product.slug %>" class="product-photo"><img src="<%= product.image_url || 'https://placehold.co/700x850/e8efe6/315a3b?text=Plant' %>" alt="<%= product.name %>"><% if(product.pet_safe){ %><span>Pet friendly</span><% }else if(product.featured){ %><span>Featured</span><% } %></a><div class="product-info"><small><%= product.category_name || '' %></small><h3><a href="/shop/<%= product.slug %>"><%= product.name %></a></h3><p><i class="fa-regular fa-sun"></i> <%= product.light_requirement || 'Care details available' %></p><div class="product-bottom"><strong><% if(product.sale_price){ %><del>$<%= product.price.toFixed(2) %></del> $<%= product.sale_price.toFixed(2) %><% }else{ %>$<%= product.price.toFixed(2) %><% } %></strong><form action="/cart/add/<%= product.id %>" method="post"><button <%= product.stock<1?'disabled':'' %>><i class="fa-solid fa-plus"></i> <%= product.stock<1?'Sold out':'Add' %></button></form></div></div></article>