<section class="section"><div class="container"><div class="product-detail"><div class="detail-image"><img src="<%= product.image_url %>" alt="<%= product.name %>"></div><div class="detail-copy"><a href="/shop?category=<%= product.category_slug %>" class="eyebrow"><%= product.category_name %></a><h1><%= product.name %></h1><div class="rating">★ <%= rating.average||'New' %> <small>(<%= rating.count %> reviews)</small></div><div class="detail-price"><% if(product.sale_price){ %><del>$<%= product.price.toFixed(2) %></del> $<%= product.sale_price.toFixed(2) %><% }else{ %>$<%= product.price.toFixed(2) %><% } %></div><p><%= product.description %></p><div class="care-grid"><div><i class="fa-regular fa-sun"></i><b>Light</b><span><%= product.light_requirement %></span></div><div><i class="fa-solid fa-droplet"></i><b>Water</b><span><%= product.water_requirement %></span></div><div><i class="fa-solid fa-chart-simple"></i><b>Difficulty</b><span><%= product.difficulty %></span></div><div><i class="fa-solid fa-paw"></i><b>Pet safe</b><span><%= product.pet_safe?'Yes':'No' %></span></div></div><p class="stock"><%= product.stock>0?product.stock+' in stock':'Currently sold out' %></p><form action="/cart/add/<%= product.id %>" method="post" class="add-form"><input type="number" name="quantity" value="1" min="1" max="<%= product.stock %>"><button class="btn-green" <%= product.stock<1?'disabled':'' %>>Add to cart</button></form></div></div><hr class="my-5"><div class="reviews"><h2>Customer reviews</h2><% if(currentUser){ %><form action="/shop/<%= product.id %>/reviews" method="post" class="review-form"><select name="rating"><option value="5">5 stars</option><option value="4">4 stars</option><option value="3">3 stars</option><option value="2">2 stars</option><option value="1">1 star</option></select><textarea name="comment" required placeholder="Share your experience"></textarea><button class="btn-dark">Submit review</button></form><% }else{ %><p><a href="/auth/login">Log in</a> to leave a review.</p><% } %><% reviews.forEach(r=>{ %><div class="review"><b><%= r.full_name %></b><span><%= '★'.repeat(r.rating) %></span><p><%= r.comment %></p></div><% }) %></div><% if(related.length){ %><div class="section-head mt-5"><h2>You may also like</h2></div><div class="product-grid"><% related.forEach(product=>{ %><%- include('../partials/product-card',{product}) %><% }) %></div><% } %></div></section>