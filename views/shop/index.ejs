<section class="page-hero"><div class="container"><small>FOG & FERN COLLECTION</small><h1>Shop plants</h1><p>Find a plant suited to your space, experience, light, and household.</p></div></section><section class="section"><div class="container"><form class="filters" method="get"><input name="q" value="<%= filters.q %>" placeholder="Search plants..."><select name="category"><option value="">All categories</option><% categories.forEach(c=>{ %><option value="<%= c.slug %>" <%= filters.category===c.slug?'selected':'' %>><%= c.name %></option><% }) %></select><select name="sort"><option value="featured" <%= filters.sort==='featured'?'selected':'' %>>Featured</option><option value="newest" <%= filters.sort==='newest'?'selected':'' %>>Newest</option><option value="price_asc" <%= filters.sort==='price_asc'?'selected':'' %>>Price low to high</option><option value="price_desc" <%= filters.sort==='price_desc'?'selected':'' %>>Price high to low</option><option value="name" <%= filters.sort==='name'?'selected':'' %>>Name</option></select><label><input type="checkbox" name="pet_safe" value="1" <%= filters.pet_safe==='1'?'checked':'' %>> Pet-friendly</label><button class="btn-dark">Apply</button></form><p class="result-count"><%= products.length %> products found</p><div class="product-grid"><% products.forEach(product=>{ %><%- include('../partials/product-card',{product}) %><% }) %></div><% if(!products.length){ %><div class="empty"><h2>No plants found</h2><p>Try changing your search or filters.</p><a href="/shop" class="btn-green">Reset filters</a></div><% } %></div></section>